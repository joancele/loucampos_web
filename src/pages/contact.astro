---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Lou Campos - Contact">
  <main
    class="flex-grow w-full max-w-7xl mx-auto px-6 md:px-12 flex flex-col justify-between py-6 md:py-24 relative min-h-[calc(100dvh-120px)] md:min-h-0"
  >
    <!-- Background Decor -->
    <div
      class="absolute top-[20%] left-[10%] w-[300px] h-[300px] bg-accent-pink/5 blur-[120px] rounded-full -z-10 animate-pulse"
    >
    </div>
    <div
      class="absolute bottom-[20%] right-[10%] w-[400px] h-[400px] bg-accent-pink/5 blur-[120px] rounded-full -z-10 animate-pulse"
      style="animation-delay: 1s;"
    >
    </div>

    <!-- Top Section: Direct Contact -->
    <section class="max-w-2xl mt-0 md:mt-12 self-start animate-fade-in-up">
      <div class="flex items-center gap-4 mb-8">
        <div class="w-[2px] h-6 bg-accent-pink"></div>
        <h3
          class="font-sans font-medium text-[10px] md:text-xs tracking-[0.2em] uppercase text-gray-400 dark:text-gray-500"
        >
          Direct Contact
        </h3>
      </div>
      <div class="space-y-8">
        <a
          class="block font-sans font-extrabold text-3xl md:text-6xl lg:text-7xl text-dark-grey dark:text-white hover:text-accent-pink transition-all duration-500 leading-tight tracking-tight"
          href="mailto:studio@loucampos.com"
        >
          studio@<br class="md:hidden" />loucampos.com
        </a>
        <p
          class="font-serif text-base md:text-2xl text-gray-500 dark:text-gray-400 italic leading-snug max-w-xl"
        >
          For all inquiries regarding available works, commissions, and press.
        </p>
      </div>
    </section>

    <!-- Bottom Section: Social & Footer -->
    <div class="w-full flex flex-col mt-4 md:mt-0">
      <!-- Social (Asymmetrical Right) -->
      <section
        class="self-end mb-12 md:mb-32 md:mr-12 lg:mr-24 animate-fade-in-up"
        style="animation-delay: 200ms;"
      >
        <div class="flex items-center justify-end gap-4 mb-8">
          <h3
            class="font-sans font-medium text-[10px] md:text-xs tracking-[0.2em] uppercase text-gray-400 dark:text-gray-500"
          >
            SOCIAL
          </h3>
          <div class="w-[2px] h-12 bg-accent-pink"></div>
        </div>
        <ul class="flex flex-col items-end gap-6 text-right">
          <li>
            <a
              class="group relative font-sans text-xl md:text-5xl font-medium text-dark-grey dark:text-white hover:text-accent-pink transition-all duration-300"
              href="https://www.instagram.com/_loucampos_/"
              target="_blank"
              rel="noopener noreferrer"
            >
              <span class="relative z-10">Instagram</span>
              <span
                class="absolute bottom-0 right-0 w-0 h-[1px] bg-accent-pink transition-all duration-300 group-hover:w-full"
              ></span>
            </a>
          </li>
        </ul>
      </section>
    </div>

    <!-- Footer Text -->
    <footer class="w-full text-center space-y-4 md:space-y-8 pb-8 md:pb-12">
      <p
        class="font-serif text-sm md:text-lg text-gray-400 dark:text-gray-500 italic tracking-wide"
      >
        Based in Spain. Available worldwide.
      </p>
      <!-- Space for centered toggle -->
      <div class="h-10 md:h-16"></div>
    </footer>
  </main>
</Layout>
