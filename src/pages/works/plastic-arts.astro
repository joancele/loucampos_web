---

<Layout title="Lou Campos - Plastic Arts Gallery">
  <main
    class="flex-grow w-full max-w-[1600px] mx-auto px-6 md:px-12 py-8 flex flex-col gap-20"
  >
    <GalleryIndex title="Index: Obra Plástica" items={seriesPreview} />

    <GallerySection
      id="majikaru"
      title="Majikaru"
      description="Primera agrupación (4 obras)."
      artworks={majikaruArtworks}
    />

    <GallerySection
      id="kyodai"
      title="Kyodai"
      description="Segunda agrupación (8 obras)."
      artworks={kyodaiArtworks}
    />

    <GallerySection
      id="barokku"
      title="Barokku"
      description="Tercera agrupación (2 obras)."
      artworks={barokkuArtworks}
    />

    <GallerySection
      id="kachiku"
      title="Kachiku"
      description="Cuarta agrupación (4 obras)."
      artworks={kachikuArtworks}
    />

    <GallerySection
      id="masuku"
      title="Masuku"
      description="Quinta agrupación (2 obras)."
      artworks={masukuArtworks}
    />

    <GallerySection
      id="zu"
      title="Zu"
      description="Sexta agrupación (1 obra)."
      artworks={zuArtworks}
    />
  </main>

  <Lightbox />
</Layout>
