---
import Layout from "../../layouts/Layout.astro";
import GalleryIndex from "../../components/gallery/GalleryIndex.astro";
import GallerySection from "../../components/gallery/GallerySection.astro";
import Lightbox from "../../components/gallery/Lightbox.astro";

const seriesPreview = [
  {
    title: "Majikaru",
    year: "2025-2026",
    image:
      "https://ik.imagekit.io/3dh5sszdn/LouCampos/Paintings/Majikaru/Wani%20no%20tora.jpg?updatedAt=1772708517705",
    href: "#majikaru",
  },
  {
    title: "Kyodai",
    year: "2017-2025",
    image:
      "https://ik.imagekit.io/3dh5sszdn/LouCampos/Paintings/Kyodai/seishun.jpg?updatedAt=1772708543307",
    href: "#kyodai",
  },
  {
    title: "Barokku",
    year: "2025",
    image:
      "https://ik.imagekit.io/3dh5sszdn/LouCampos/Paintings/Barokku/kabin%20to%20komori.jpg?updatedAt=1772708499881",
    href: "#barokku",
  },
  {
    title: "Kachiku",
    year: "2020",
    image:
      "https://ik.imagekit.io/3dh5sszdn/LouCampos/Paintings/Kachiku/Usagiuma.jpg?updatedAt=1772708462422",
    href: "#kachiku",
  },
  {
    title: "Masuku",
    year: "2025",
    image:
      "https://ik.imagekit.io/3dh5sszdn/LouCampos/Paintings/Masuku/Kaerumonsuta.jpg?updatedAt=1772708483561",
    href: "#masuku",
  },
  {
    title: "Zu",
    year: "2024-2026",
    image:
      "https://ik.imagekit.io/3dh5sszdn/LouCampos/Paintings/Zu/usucha%20ningyo.jpg?updatedAt=1772708441866",
    href: "#zu",
  },
  {
    title: "Gazou",
    year: "2025",
    image:
      "https://ik.imagekit.io/3dh5sszdn/LouCampos/Paintings/Gazou/Keiko.jpeg?updatedAt=1772715968846",
    href: "#gazou",
  },
];

import paintingData from "../../data/painting.json";

const majikaruArtworks = paintingData.majikaru;
const kyodaiArtworks = paintingData.kyodai;
const barokkuArtworks = paintingData.barokku;
const kachikuArtworks = paintingData.kachiku;
const masukuArtworks = paintingData.masuku;
const zuArtworks = paintingData.zu;
const gazouArtworks = paintingData.gazou;
---

<Layout title="Lou Campos - Painting Gallery">
  <main
    class="flex-grow w-full max-w-[1600px] mx-auto px-6 md:px-12 py-8 flex flex-col gap-20"
  >
    <GalleryIndex title="Index: Obra Plástica" items={seriesPreview} />

    <GallerySection
      id="majikaru"
      title="Majikaru"
      description={`Esta línea de obra pictórica se manifiesta como una reinterpretación del Superflat japonés bajo una mirada whimsical y crítica, centrada en cómo la ficcionalidad de los elementos altera nuestra lectura del entorno. A través de la bidimensionalidad y el pastiche neopop, se configuran escenarios donde la rigidez del lenguaje visual se quiebra, invitando al espectador a dudar de la frontera entre el ser vivo y el objeto inanimado.`}
      artworks={majikaruArtworks}
    />

    <GallerySection
      id="kyodai"
      title="Kyodai"
      description={`Esta línea de obra pictórica se define como una cartografía del Antropoceno articulada a través del Realismo Mágico contemporáneo. 
      En piezas que superan el metro de longitud, se utiliza el papel para orquestar un diálogo entre la inmensidad de la naturaleza y la huella de lo humano, cuestionando las jerarquías visuales que dictan nuestra relación con el entorno. Mediante el uso del collage y contextos inesperados, se reflexiona sobre el cambio climático y la pérdida de la frontera entre el mundo vivo y el simulacro, creando estancias donde el espectador pierde la brújula de lo que es real.`}
      artworks={kyodaiArtworks}
    />

    <GallerySection
      id="barokku"
      title="Barokku"
      description={`Esta línea de obra pictórica se define por un claroscuro conceptual que busca generar un estado de desasosiego en la percepción del espectador. Mediante una técnica que remite a la pintura barroca, se sitúan animales en contextos inesperados y domésticos, rompiendo la narrativa convencional del espacio. 
      La obra funciona como un espejo de la realidad donde la vida orgánica y el espejismo plástico conviven en una danza de sombras, obligándonos a replantear nuestras categorías perceptuales sobre lo que consideramos digno de ser retratado.`}
      artworks={barokkuArtworks}
    />

    <GallerySection
      id="kachiku"
      title="Kachiku"
      description={`Esta línea de obra pictórica se manifiesta como un ejercicio de surrealismo ecocéntrico, donde la sintiencia animal deja de ser un tema periférico para convertirse en el eje que sostiene la realidad. A través de figuras híbridas —como el bóvido que carga literalmente con el ecosistema en su lomo—, se reflexiona sobre el cambio climático y la responsabilidad ontológica de lo vivo. 
      En estas piezas, el paisaje no es un decorado, sino una extensión orgánica del sujeto, rompiendo lo que separa al animal de su territorio y elevando a los "domesticados" a una categoría de monumentos vivientes.`}
      artworks={kachikuArtworks}
    />

    <GallerySection
      id="masuku"
      title="Masuku"
      description={`En este conjunto de piezas, se propone un acercamiento al Neo-Japonismo actual, rescatando la simbología de las máscaras Hannya y Oni para poner en duda la supuesta realidad de nuestros constructos culturales. 
      Bajo un cromatismo eléctrico y vibrante, se sitúan pequeños seres sintientes en el centro mismo del rito, disolviendo las fronteras impuestas que suelen aislar la naturaleza animal de cualquier dimensión espiritual o simbólica.`}
      artworks={masukuArtworks}
    />

    <GallerySection
      id="zu"
      title="Zu"
      description={`Línea de dibujos.`}
      artworks={zuArtworks}
    />

    <GallerySection
      id="gazou"
      title="Gazou"
      description={`Línea de retratos.`}
      artworks={gazouArtworks}
    />
  </main>

  <Lightbox />
</Layout>
