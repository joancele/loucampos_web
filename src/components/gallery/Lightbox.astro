---

---

<div
  class="fixed inset-0 z-[100] hidden bg-white/95 dark:bg-black/95 items-center justify-center p-4 md:p-8 overflow-hidden"
  id="lightbox"
>
  <button
    class="fixed top-8 right-8 md:top-12 md:right-12 text-dark-grey dark:text-white hover:text-accent-pink transition-colors focus:outline-none z-[120]"
    id="lightbox-close"
  >
    <span class="material-symbols-outlined text-4xl">close</span>
  </button>
  <div
    class="relative flex flex-col landscape:flex-row lg:flex-row items-stretch justify-center w-[98vw] lg:w-[95vw] max-w-[2000px] mx-auto h-[95dvh] lg:h-[90dvh] bg-white dark:bg-[#1a1a1a] shadow-2xl overflow-hidden"
  >
    <!-- Contenedor de la Imagen (Protagonista 90%) -->
    <div
      class="flex-grow landscape:flex-[0_0_80%] lg:flex-[0_0_90%] relative bg-[#fafafa] dark:bg-[#0a0a0a] flex items-center justify-center p-2 md:p-4 overflow-hidden group/img"
    >
      <button
        class="absolute z-[110] p-2 md:p-3 rounded-full hidden opacity-0 md:opacity-0 md:group-hover/img:opacity-100 pointer-events-auto backdrop-blur-sm shadow-md bg-white/70 dark:bg-black/50 text-dark-grey dark:text-white hover:bg-accent-pink hover:text-white transition-all duration-300 focus:outline-none left-4 bottom-4 translate-y-0 md:bottom-auto md:top-1/2 md:-translate-y-1/2 md:left-8"
        id="lightbox-prev"
        aria-label="Previous image"
      >
        <span class="material-symbols-outlined text-3xl md:text-4xl block"
          >chevron_left</span
        >
      </button>

      <button
        class="absolute z-[110] p-2 md:p-3 rounded-full hidden opacity-0 md:opacity-0 md:group-hover/img:opacity-100 pointer-events-auto backdrop-blur-sm shadow-md bg-white/70 dark:bg-black/50 text-dark-grey dark:text-white hover:bg-accent-pink hover:text-white transition-all duration-300 focus:outline-none right-4 bottom-4 translate-y-0 md:bottom-auto md:top-1/2 md:-translate-y-1/2 md:right-8"
        id="lightbox-next"
        aria-label="Next image"
      >
        <span class="material-symbols-outlined text-3xl md:text-4xl block"
          >chevron_right</span
        >
      </button>
      <img
        alt="Expanded View"
        class="max-w-full max-h-full object-contain scale-100 transition-all duration-300 opacity-100"
        id="lightbox-img"
        src=""
      />
    </div>

    <!-- Contenedor de Información (Extensión Secundaria Minimalista 10%) -->
    <div
      id="lightbox-info"
      class="w-full min-h-[150px] md:min-h-[200px] landscape:min-h-0 landscape:w-auto landscape:flex-[0_0_25%] lg:flex-[0_0_20%] min-w-[250px] md:min-w-[300px] p-5 md:p-6 lg:p-8 flex flex-col justify-end bg-white dark:bg-[#151515] opacity-0 transition-opacity duration-300 border-t landscape:border-t-0 landscape:border-l lg:border-t-0 lg:border-l border-gray-100 dark:border-gray-800"
    >
      <h3
        id="lightbox-title"
        class="font-sans font-medium text-xs md:text-sm text-gray-700 dark:text-gray-300 mb-1 uppercase tracking-widest break-words"
      >
      </h3>
      <p
        id="lightbox-year"
        class="font-sans text-[11px] text-accent-pink mb-2 tracking-widest font-semibold"
      >
      </p>
      <div class="h-[1px] w-4 bg-gray-200 dark:bg-gray-800 mb-2"></div>
      <p
        id="lightbox-desc"
        class="font-serif text-xs md:text-sm leading-relaxed text-gray-500 dark:text-gray-500 line-clamp-6"
      >
      </p>
    </div>
  </div>
</div>

<script src="../../scripts/components/gallery/Lightbox.js"></script>
