---
export interface Artwork {
    title: string;
    year: string;
    description: string;
    image: string;
    alt: string;
}

export interface Props {
    id: string;
    title: string;
    description: string;
    artworks: Artwork[];
}

const { id, title, description, artworks } = Astro.props;
---

<section id={id}>
    <div class="max-w-3xl mb-12 mt-4">
        <a
            href="#top"
            class="inline-flex items-center gap-2 text-xs font-montserrat uppercase tracking-wider text-dark-grey dark:text-gray-400 hover:text-accent-pink dark:hover:text-accent-pink transition-colors mb-6 group"
        >
            <span
                class="material-symbols-outlined text-sm transition-transform group-hover:-translate-x-1"
                >arrow_back</span
            >
            <span data-i18n="gallery.back_to_index">Volver al índice</span>
        </a>
        <div class="flex items-center gap-4 mb-4">
            <span class="h-[1px] w-12 bg-accent-pink"></span>
            <h2
                class="font-sans font-bold text-4xl md:text-5xl text-dark-grey dark:text-text-dark tracking-tight"
            >
                {title}
            </h2>
        </div>
        <div
            class="font-serif text-lg md:text-xl text-gray-600 dark:text-gray-300 leading-relaxed max-w-2xl pl-16 space-y-2"
        >
            {
                description
                    .split("\n")
                    .map((line) => line.trim())
                    .filter((line) => line.length > 0)
                    .map((paragraph) => (
                        <p class="whitespace-pre-line">
                            {"\u00A0\u00A0\u00A0"}
                            {paragraph}
                        </p>
                    ))
            }
        </div>
    </div>
    <div
        class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 md:gap-8 lg:gap-10"
    >
        {
            artworks.map((artwork) => (
                <div
                    class="group relative aspect-square w-full cursor-pointer overflow-hidden bg-gray-100 dark:bg-gray-800"
                    data-title={artwork.title}
                    data-year={artwork.year}
                    data-description={artwork.description}
                >
                    <img
                        alt={artwork.alt}
                        class="h-full w-full object-cover transition-transform duration-700 ease-in-out group-hover:scale-105"
                        src={artwork.image}
                    />
                    <div class="absolute inset-0 bg-white/80 dark:bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
                        <h3 class="font-sans text-dark-grey dark:text-white text-lg tracking-[0.2em] uppercase font-light translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
                            {artwork.title}
                        </h3>
                    </div>
                </div>
            ))
        }
    </div>

    <div class="mt-12 text-center hidden gallery-toggle-wrapper">
        <button
            class="gallery-toggle-btn mx-auto group relative overflow-hidden rounded-full border border-gray-200 dark:border-gray-800 bg-white dark:bg-[#111] px-8 py-3 w-48 transition-all hover:border-accent-pink dark:hover:border-accent-pink hover:shadow-[0_0_20px_rgba(255,20,147,0.15)] focus:outline-none"
        >
            <div
                class="absolute inset-0 bg-gradient-to-r from-accent-pink to-accent-pink opacity-0 transition-opacity group-hover:opacity-10"
            >
            </div>
            <span
                class="relative flex items-center justify-center gap-2 font-sans text-sm tracking-[0.2em] font-bold uppercase text-dark-grey dark:text-gray-300 transition-colors group-hover:text-accent-pink"
            >
                <span data-i18n="gallery.view_more" class="gallery-toggle-text"
                    >Ver más</span
                >
                <span
                    data-i18n="gallery.view_less"
                    class="gallery-toggle-text hidden">Ver menos</span
                >
                <span
                    class="material-symbols-outlined gallery-toggle-icon text-lg transition-transform duration-300"
                    >expand_more</span
                >
            </span>
        </button>
    </div>
</section>

<script src="../../scripts/components/gallery/GallerySection.js"></script>
